# =========================================
.env
.env.*
!.env.example
!.env.*.example

# =========================================
# Dependencies
# =========================================
node_modules/
backend/node_modules/
frontend/node_modules/

# Package manager caches
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# =========================================
# Build Outputs
# =========================================
dist/
build/
backend/dist/
frontend/dist/
frontend/.vite/

# TypeScript incremental build cache
*.tsbuildinfo

# =========================================
# Test / Coverage Outputs
# =========================================
coverage/
backend/coverage/
frontend/coverage/

# Cypress artifacts
frontend/cypress/videos/
frontend/cypress/screenshots/
frontend/cypress/downloads/

# =========================================
# Prisma / Local Database Files
# =========================================
# Keep real Prisma migrations committed.
# Ignore only local temporary DB files.
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/*.db
backend/prisma/*.db-journal

*.db
*.sqlite
*.sqlite3

# =========================================
# Logs
# =========================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================
# OS Files
# =========================================
.DS_Store
Thumbs.db

# =========================================
# Editor / IDE Files
# =========================================
.idea/
.vscode/

# =========================================
# Replit / Local Generated Files
# =========================================
# These are local/Replit-specific and should not be part of the submitted GitHub project.
.replit
replit.md
replit.nix
attached_assets/
.cache/
.local/
.agents/
.claude/

# =========================================
# Docker / Runtime Local Files
# =========================================
