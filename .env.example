# ----- PostgreSQL (used by docker-compose for the local Docker stack) -----
POSTGRES_USER=investor_user
POSTGRES_PASSWORD=investor_password
POSTGRES_DB=investor_db
POSTGRES_PORT=5432

# Connection string used by the backend Prisma client.
# Inside docker-compose the host is the postgres service name.
# Locally (without docker) you can point this at any reachable Postgres instance,
# e.g. postgresql://investor_user:investor_password@localhost:5432/investor_db
DATABASE_URL=postgresql://investor_user:investor_password@postgres:5432/investor_db

# ----- Backend (NestJS) -----
BACKEND_PORT=8000
# Loopback for local Replit dev; set to 0.0.0.0 in Docker/CI/prod.
BACKEND_HOST=127.0.0.1
NODE_ENV=development

# ----- Frontend (React + Vite) -----
# Host port the SPA is served on. Replit's dev workflow uses 5000 directly;
# Docker Compose maps this var to the nginx container's port 80.
FRONTEND_PORT=5173
# Public base URL the frontend should call for API requests.
VITE_API_BASE_URL=http://localhost:8000
